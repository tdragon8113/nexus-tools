# Docker Compose（docker-compose.yml / docker-compose.prod.yml）用。
# 中间件（MySQL/Redis/MQ 等）若在 Nacos 配置里维护，此处只需 Nacos 与镜像相关变量；与 ACK 上注入方式一致即可。
# 本机 java -jar / Maven 见仓库根目录 .env.example
NACOS_SERVER_ADDR=nacos-server:8848
NACOS_USERNAME=nacos
NACOS_PASSWORD=your_nacos_password
# 决定拉取的 Data ID：nexus-*-<profile>.yml；可不写，compose 内默认 prod
# SPRING_PROFILES_ACTIVE=prod

# 阿里云镜像仓库
ALIYUN_REGISTRY=registry.cn-hangzhou.aliyuncs.com
ALIYUN_NAMESPACE=your_namespace