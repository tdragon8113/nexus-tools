# 复制为 .env 后填写真实值（.env 已 gitignore，勿提交）
# 用法：在仓库根目录执行  set -a && source .env && set +a  再 cd backend 跑 Maven / java -jar
# IntelliJ：Run Configuration → Environment variables 与下表同名逐项填写，或安装 EnvFile 指向本文件副本

# Spring profile（决定 Nacos 拉取的 Data ID：nexus-*-<profile>.yml，未设置时 application.yml 默认为 prod）
# SPRING_PROFILES_ACTIVE=prod

# Nacos（与 backend/*/application.yml 中 spring.cloud.nacos 占位符对应）
NACOS_SERVER_ADDR=127.0.0.1:8848
NACOS_USERNAME=nacos
NACOS_PASSWORD=
# 服务注册分组：本地开发用 DEV_GROUP，生产用 DEFAULT_GROUP
NACOS_GROUP=DEV_GROUP

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# MySQL（各服务库名在 application.yml 的 jdbc url 中已写死）
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=

# RabbitMQ（user-service 与 workspace-service 共用同一套变量与 application.yml 默认值）
RABBITMQ_HOST=127.0.0.1
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=rabbitmq
RABBITMQ_PASSWORD=

# JWT（至少 256 位密钥用于 HS256 签名）
JWT_SECRET_KEY=your-256-bit-secret-key-here-at-least-32-characters
JWT_ACCESS_TOKEN_EXPIRATION=900      # 15 分钟（秒）
JWT_REFRESH_TOKEN_EXPIRATION=604800  # 7 天（秒）

# Micrometer Tracing（Zipkin）
TRACING_ENABLED=true
TRACING_SAMPLING_PROBABILITY=1.0     # 采样率：1.0=100%，生产建议 0.1
ZIPKIN_ENDPOINT=http://127.0.0.1:9411/api/v2/spans
