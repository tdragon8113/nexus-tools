<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.nexus.workspace.infrastructure.persistence.mapper.TodoMapper">

    <resultMap id="TodoResultMap" type="com.nexus.workspace.domain.model.todo.Todo">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="title" property="title"/>
        <result column="description" property="description"/>
        <result column="status" property="statusFromCode"/>
        <result column="priority" property="priorityFromCode"/>
        <result column="due_date" property="dueDate"/>
        <result column="completed_at" property="completedAt"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
    </resultMap>

    <select id="findByUserId" resultMap="TodoResultMap">
        SELECT * FROM todos WHERE user_id = #{userId} ORDER BY due_date ASC, priority DESC
    </select>

    <select id="findByUserIdAndDate" resultMap="TodoResultMap">
        SELECT * FROM todos WHERE user_id = #{userId} AND due_date = #{dueDate} ORDER BY priority DESC
    </select>

    <select id="findByUserIdAndDateRange" resultMap="TodoResultMap">
        SELECT * FROM todos WHERE user_id = #{userId}
        AND due_date BETWEEN #{startDate} AND #{endDate}
        ORDER BY due_date ASC, priority DESC
    </select>
</mapper>