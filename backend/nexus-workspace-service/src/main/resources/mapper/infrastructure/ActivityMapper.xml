<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.nexus.workspace.infrastructure.persistence.mapper.ActivityMapper">

    <resultMap id="ActivityResultMap" type="com.nexus.workspace.domain.model.activity.Activity">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="title" property="title"/>
        <result column="category" property="categoryFromString"/>
        <result column="start_time" property="startTime"/>
        <result column="end_time" property="endTime"/>
        <result column="duration_minutes" property="durationMinutes"/>
        <result column="notes" property="notes"/>
        <result column="created_at" property="createdAt"/>
    </resultMap>

    <select id="findByUserId" resultMap="ActivityResultMap">
        SELECT * FROM activities WHERE user_id = #{userId} ORDER BY start_time DESC
    </select>

    <select id="findByUserIdAndDateRange" resultMap="ActivityResultMap">
        SELECT * FROM activities WHERE user_id = #{userId}
        AND start_time BETWEEN #{startTime} AND #{endTime}
        ORDER BY start_time ASC
    </select>
</mapper>