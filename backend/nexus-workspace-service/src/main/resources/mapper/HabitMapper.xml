<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.nexus.workspace.mapper.HabitMapper">

    <resultMap id="HabitResultMap" type="com.nexus.workspace.entity.Habit">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="name" property="name"/>
        <result column="icon" property="icon"/>
        <result column="target" property="target"/>
        <result column="custom_days" property="customDays"/>
        <result column="version" property="version"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
    </resultMap>

    <select id="findById" resultMap="HabitResultMap">
        SELECT * FROM habits WHERE id = #{id}
    </select>

    <select id="findByUserId" resultMap="HabitResultMap">
        SELECT * FROM habits WHERE user_id = #{userId} ORDER BY created_at DESC
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO habits (user_id, name, icon, target, custom_days, created_at)
        VALUES (#{userId}, #{name}, #{icon}, #{target}, #{customDays}, #{createdAt})
    </insert>

    <update id="update">
        UPDATE habits SET
            name = #{name},
            icon = #{icon},
            target = #{target},
            custom_days = #{customDays},
            updated_at = #{updatedAt}
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM habits WHERE id = #{id}
    </delete>
</mapper>