<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.nexus.workspace.mapper.HabitCheckinMapper">

    <resultMap id="HabitCheckinResultMap" type="com.nexus.workspace.entity.HabitCheckin">
        <id column="id" property="id"/>
        <result column="habit_id" property="habitId"/>
        <result column="user_id" property="userId"/>
        <result column="checkin_date" property="checkinDate"/>
        <result column="created_at" property="createdAt"/>
    </resultMap>

    <select id="findById" resultMap="HabitCheckinResultMap">
        SELECT * FROM habit_checkins WHERE id = #{id}
    </select>

    <select id="findByHabitId" resultMap="HabitCheckinResultMap">
        SELECT * FROM habit_checkins WHERE habit_id = #{habitId} ORDER BY checkin_date DESC
    </select>

    <select id="findByHabitIdAndDateRange" resultMap="HabitCheckinResultMap">
        SELECT * FROM habit_checkins
        WHERE habit_id = #{habitId}
        AND checkin_date BETWEEN #{startDate} AND #{endDate}
        ORDER BY checkin_date ASC
    </select>

    <select id="findByHabitIdAndDate" resultMap="HabitCheckinResultMap">
        SELECT * FROM habit_checkins WHERE habit_id = #{habitId} AND checkin_date = #{checkinDate}
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO habit_checkins (habit_id, user_id, checkin_date, created_at)
        VALUES (#{habitId}, #{userId}, #{checkinDate}, #{createdAt})
    </insert>

    <delete id="deleteById">
        DELETE FROM habit_checkins WHERE id = #{id}
    </delete>
</mapper>