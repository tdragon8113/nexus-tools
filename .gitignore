# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Xcode
# Nested projects (e.g. mac-app/*.xcodeproj): * alone does not match path segments
**/xcuserdata/
*.xcuserstate
*.xcodeproj/project.xcworkspace/
*.xcodeproj/xcuserdata/
*.xcworkspace/xcuserdata/
build/
DerivedData/
*.ipa
*.dSYM.zip
*.dSYM

# Swift Package Manager
.build/
.swiftpm/

# Java/Maven
target/
*.jar
*.war
*.class
.settings/
.project
.classpath

# SkyWalking Agent (external dependency)
skywalking-agent/

# IntelliJ IDEA (keep .idea/.gitignore for project-specific)
.idea/
*.iml

# Docker
docker/.env

# Logs
*.log
logs/

# Environment
.env
.env.local
.env.*.local
# Local Spring profile files often contain secrets
**/application-local.yml

# Node.js / Nuxt
node_modules/
.nuxt/
.output/
.nitro/
dist/

# Claude Code
.claude/*

# Documentation generated files
docs/CODEMAPS/